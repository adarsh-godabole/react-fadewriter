{
  "name": "react-fadewriter",
  "version": "0.1.6",
  "type": "module",
  "description": "A React component that fades in text character by character",
  "author": "Adarsh",
  "license": "MIT",
  "keywords": [
    "react",
    "animation",
    "fade",
    "typewriter",
    "text"
  ],
  "main": "./dist/index.cjs",
